import psycopg2
import csv

conn = psycopg2.connect(
    dbname="bekasyl",
    user="postgres",
    password="1234",
    host="localhost",
    port="5432"
)

cur = conn.cursor()

cur.execute("""
CREATE TABLE IF NOT EXISTS phonebook (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) UNIQUE,
    phone VARCHAR(20)
)
""")
conn.commit()

def add_or_update_user(name, phone):
    cur.execute("""
    INSERT INTO phonebook (name, phone)
    VALUES (%s, %s)
    ON CONFLICT (name)
    DO UPDATE SET phone = EXCLUDED.phone
    """, (name, phone))
    conn.commit()

def search_user(pattern):
    cur.execute("""
    SELECT * FROM phonebook
    WHERE name ILIKE %s OR phone ILIKE %s
    """, (f"%{pattern}%", f"%{pattern}%"))
    return cur.fetchall()

def delete_user(name=None, phone=None):
    if not name and not phone:
        return
    cur.execute("""
    DELETE FROM phonebook
    WHERE (%s IS NOT NULL AND name = %s)
       OR (%s IS NOT NULL AND phone = %s)
    """, (name, name, phone, phone))
    conn.commit()

def show_all():
    cur.execute("SELECT * FROM phonebook ORDER BY id")
    return cur.fetchall()

def load_from_csv(file):
    with open(file, "r") as f:
        reader = csv.reader(f)
        for row in reader:
            add_or_update_user(row[0], row[1])

def paginate(limit, offset):
    cur.execute("SELECT * FROM phonebook ORDER BY id LIMIT %s OFFSET %s", (limit, offset))
    return cur.fetchall()

while True:
    print("\n1 - Add contact")
    print("2 - Load from CSV")
    print("3 - Show all")
    print("4 - Search")
    print("5 - Update contact")
    print("6 - Delete contact")
    print("7 - Paginate")
    print("0 - Exit")

    choice = input("Choose: ")

    if choice == "1":
        name = input("Name: ")
        phone = input("Phone: ")
        add_or_update_user(name, phone)

    elif choice == "2":
        file = input("CSV file path: ")
        load_from_csv(file)

    elif choice == "3":
        for r in show_all():
            print(r)

    elif choice == "4":
        pattern = input("Search pattern: ")
        for r in search_user(pattern):
            print(r)

    elif choice == "5":
        old_name = input("Old name: ")
        new_name = input("New name (leave empty to skip): ")
        new_phone = input("New phone (leave empty to skip): ")
        if new_name:
            cur.execute("UPDATE phonebook SET name=%s WHERE name=%s", (new_name, old_name))
        if new_phone:
            cur.execute("UPDATE phonebook SET phone=%s WHERE name=%s", (new_phone, old_name))
        conn.commit()

    elif choice == "6":
        name = input("Delete by name (leave empty if not): ")
        phone = input("Delete by phone (leave empty if not): ")
        delete_user(name if name else None, phone if phone else None)

    elif choice == "7":
        limit = int(input("Limit: "))
        offset = int(input("Offset: "))
        for r in paginate(limit, offset):
            print(r)

    elif choice == "0":
        break

cur.close()
conn.close()
